# Model provider — local (default, no key needed) | anthropic | openai | gemini
MODEL_PROVIDER=local

# Local model (Ollama default)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=granite4:micro

# Frontier providers (optional — enables strong tier routing)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ICP data sources (optional)
# CRUNCHBASE_API_KEY=...   # https://data.crunchbase.com/docs
# HUNTER_API_KEY=...       # https://hunter.io/api (email finder, 25/mo free)

# Event sources (optional)
# EVENTBRITE_API_KEY=...   # https://www.eventbrite.com/platform/api

# Calendar integration (optional)
# GOOGLE_CALENDAR_CREDENTIALS=./credentials.json

# Offline mode — forces all tools to use fixtures
# AGENT_OFFLINE=1
